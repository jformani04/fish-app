{
  "expo": {
    "name": "Anglr",
    "slug": "anglr",
    "version": "1.0.0",
    "icon": "./assets/images/appIcon.png",
    "orientation": "portrait",
    "scheme": "anglr",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/images/appIcon.png"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anglr",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/appIcon.png",
        "backgroundColor": "#111315"
      },
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCdsxNaAwVRc3NKKptYKAODzfuew2AvuU8"
        }
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/appIcon.png"
    },
    "splash": {
      "image": "./assets/images/splashScreenIcon.png",
      "resizeMode": "contain",
      "backgroundColor": "#111315"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-sqlite",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Anglr to use your location to prefill catch location."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Anglr to access your camera",
          "microphonePermission": "Allow Anglr to access your microphone",
          "recordAudioAndroid": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "37fc6544-015c-4196-b898-520e2971335e"
      }
    },
    "owner": "jformani"
  }
}
